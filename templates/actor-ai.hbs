<div class="actor-ai">
    <div class="actor-ai-gen-window">
        <div class="actor-ai-scroll">
            <div class="actor-ai-response">
                <div class="actor-ai-img">
                    {{#if actorInput.imageSrc}}
                        <img class="actor-ai-img-gen" src="{{actorInput.imageSrc}}" data-action="previewImage">
                    {{else}}
                        <img class="actor-ai-img-gen" src="icons/svg/mystery-man.svg" data-action="previewImage">
                    {{/if}}
                    {{#if (eq context.stage "final")}}
                        <div class="form-group stacked actor-ai-image-prompt">
                            <label>{{localize "AActors.General.GenerateImage"}}</label>
                            <textarea name="actorInput.imagePrompt" class="actor-ai-image-description">{{actorInput.imagePrompt}}</textarea>
                        </div>
                        <div class="actor-ai-img-buttons">
                            <button type="button" class="sheet-button" data-action="generate">{{localize "AActors.General.GenerateImage"}}</button>
                        </div>
                    {{/if}}
                </div>
                {{#if (ne context.stage "init")}}
                    <div class="actor-ai-sheet-body">
                        {{editor enrichedHtml target="actorInput.html" engine="prosemirror" button=true owner=owner editable=editable}}
                    </div>
                {{/if}}
            </div>
            <div class="actor-ai-loader-wrapper">
                {{#if (ne context.stage "final")}}
                    <div class="actor-ai-loader"></div>
                    <div class="actor-ai-loader-message">
                        {{ context.stageDescription }}
                    </div>
                {{/if}}
            </div>
        </div>
        <footer class="form-footer actor-ai-footer">
            <div class="form-group">
                <label>{{localize "AActors.General.SelectFolder"}}</label>
                <div class="form-fields">
                    <select name="folder" data-dtype="String" class="actor-ai-folders">
                        {{selectOptions folders selected=folder valueAttr="value" labelAttr="name" localize=false}}
                    </select>
                </div>
            </div>
            <button type="button" data-action="save">{{localize "AActors.General.Save"}}</button>
        </footer>
    </div>
</div>
